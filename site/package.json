{
  "name": "suigraph-site",
  "version": "1.0.0",
  "description": "a graphql based block explorer (static Walrus site)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build-single-file.mjs",
    "build:check": "node scripts/build-single-file.mjs --check",
    "baseline": "node scripts/report-baseline.mjs",
    "check:bundle-boundaries": "node scripts/check-bundle-boundaries.mjs",
    "deploy:walrus": "node scripts/deploy-walrus-site.mjs",
    "fixtures:scan": "node scripts/scan-address-fixtures.mjs",
    "smoke:coin": "node scripts/smoke-coin-search.mjs",
    "smoke:tx": "node scripts/smoke-tx-route.mjs",
    "gql:surface": "node scripts/report-gql-surface.mjs",
    "perf:budgets": "node scripts/report-perf-budgets.mjs",
    "schema:refresh": "node scripts/refresh-schema-root-fields.mjs",
    "schema:coverage": "node scripts/report-schema-coverage.mjs",
    "schema:check": "node scripts/report-schema-coverage.mjs --check",
    "validate": "npm run build:check && node scripts/check-syntax.mjs && node scripts/check-quality.mjs && node scripts/check-bundle-boundaries.mjs && node scripts/check-accounting-guards.mjs && npm run schema:check",
    "check:accounting": "node scripts/check-accounting-guards.mjs",
    "smoke:address": "node scripts/smoke-address-defi.mjs --expect-filter-hides"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "terser": "^5.46.0"
  }
}
